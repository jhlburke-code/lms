---
import Layout from '../../layouts/Layout.astro';
import { makeBrowserClient, makeAuthenticatedClient, getCurrentUser } from '../../lib/supabase';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/catalog');

const user = await getCurrentUser(Astro);
if (!user) {
  return Astro.redirect(`/login?next=/c/${slug}`);
}

const browser = makeBrowserClient(Astro);
const { data: course } = await browser
  .from('courses')
  .select('id, slug, title, content_type, asset_url, widget_key, duration_minutes')
  .eq('slug', slug)
  .maybeSingle();

if (!course) return new Response('Not found', { status: 404 });

const auth = makeAuthenticatedClient(Astro);
const { data: enr } = await auth
  .from('enrollments')
  .select('user_id')
  .eq('user_id', user.id)
  .eq('course_id', (course as any).id)
  .maybeSingle();
if (!enr) return Astro.redirect(`/c/${slug}`);
---
<Layout title={course.title}>
  <section class="container">
    <a href="/me" class="muted" style="font-size: 14px;">← My learning</a>
    <h1 style="margin-top: 16px;">{course.title}</h1>

    <div class="card" style="margin-top: 24px; padding: 0; overflow: hidden;">
      {course.content_type === 'elearning' && course.widget_key && (
        <iframe
          src={`https://elearning-test.jhl-burke.workers.dev/widgets/${course.widget_key}/index.html`}
          style="width: 100%; min-height: 600px; border: 0;"
          allow="clipboard-write"
        ></iframe>
      )}
      {course.content_type === 'pdf' && course.asset_url && (
        <iframe
          src={course.asset_url}
          style="width: 100%; min-height: 800px; border: 0;"
        ></iframe>
      )}
      {course.content_type === 'youtube' && course.asset_url && (
        <div style="position: relative; padding-bottom: 56.25%; height: 0;">
          <iframe
            src={course.asset_url}
            style="position: absolute; inset: 0; width: 100%; height: 100%; border: 0;"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          ></iframe>
        </div>
      )}
      {course.content_type === 'workshop' && (
        <div style="padding: 24px;">
          <h2>Workshop</h2>
          <p class="muted">Workshop runner lands in Phase 4. For now, see the catalog card.</p>
        </div>
      )}
    </div>
  </section>
</Layout>
