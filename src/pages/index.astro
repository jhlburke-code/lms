---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Home">
  <section class="container" style="padding-top: 64px; text-align: center;">
    <h1 style="font-size: 48px;">AIINOD Learning Hub</h1>
    <p class="muted" style="font-size: 18px; max-width: 640px; margin: 0 auto 32px;">
      Interactive eLearnings, workbooks, and live workshops for the people side of AI.
    </p>
    <div style="display: flex; gap: 16px; justify-content: center;">
      <a href="/catalog" class="btn btn-primary">Browse catalog</a>
      <a href="/login" class="btn btn-secondary">Sign in</a>
    </div>
  </section>

  <section class="container" style="margin-top: 64px;">
    <div class="card" style="max-width: 720px; margin: 0 auto; text-align: center;">
      <h2>For operators</h2>
      <p class="muted">Sign in with your work email — we'll send you a magic link, no password needed.</p>
      <a href="/login" class="btn btn-primary">Sign in</a>
    </div>
  </section>
</Layout>
