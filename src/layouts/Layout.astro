---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'AIINOD Learning Hub' } = Astro.props;
import '../styles/global.css';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Learning Hub</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <header style="background: var(--bg); color: var(--text-on-bg); padding: 16px 24px;">
      <div style="max-width: 1100px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between;">
        <a href="/" style="color: white; font-weight: 700; font-size: 18px; text-decoration: none;">
          AIINOD Learning
        </a>
        <nav style="display: flex; gap: 24px;">
          <a href="/catalog" style="color: white;">Catalog</a>
          <a href="/me" style="color: white;">My learning</a>
          <a href="/login" style="color: white;">Sign in</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer style="margin-top: 64px; padding: 24px; text-align: center; color: var(--text-muted); font-size: 13px;">
      AIINOD Learning · v0
    </footer>
  </body>
</html>
